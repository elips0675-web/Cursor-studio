
{
  "entities": {
    "UserProfile": {
      "title": "Профиль пользователя",
      "description": "Основная информация о пользователе приложения.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "age": { "type": "number" },
        "city": { "type": "string" },
        "height": { "type": "number" },
        "zodiac": { "type": "string" },
        "datingGoal": { "type": "string" },
        "work": { "type": "string" },
        "education": { "type": "string" },
        "gender": { "type": "string" },
        "lookingFor": { "type": "string" },
        "pets": { "type": "string" },
        "sleepSchedule": { "type": "string" }
      }
    },
    "SystemBroadcast": {
      "title": "Системная рассылка",
      "description": "Сообщение, отправленное администратором всем или группе пользователей.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "subject": { "type": "string" },
        "target": { "type": "string", "enum": ["all", "premium", "new"] },
        "channel": { "type": "string", "enum": ["app", "email"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "senderId": { "type": "string" }
      },
      "required": ["text", "target", "channel", "createdAt"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Данные профиля пользователя"
    },
    "/broadcasts/{broadcastId}": {
      "schema": "SystemBroadcast",
      "description": "История системных рассылок"
    }
  }
}
