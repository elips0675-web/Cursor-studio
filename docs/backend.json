
{
  "entities": {
    "UserProfile": {
      "title": "Профиль пользователя",
      "description": "Основная информация о пользователе приложения.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "age": { "type": "number" },
        "city": { "type": "string" },
        "height": { "type": "number" },
        "zodiac": { "type": "string" },
        "datingGoal": { "type": "string" },
        "work": { "type": "string" },
        "education": { "type": "string" },
        "gender": { "type": "string" },
        "lookingFor": { "type": "string" },
        "pets": { "type": "string" },
        "sleepSchedule": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Данные профиля пользователя"
    }
  }
}
